MINIMAX_DEFAULT_MODEL=MiniMax-M3
AI_DEFAULT_PROVIDER=minimax
AI_FALLBACK_PROVIDERS=minimax,unified,nvidia,deepseek,anthropic,openai

# Coolify Deployment
COOLIFY_WEBHOOK_URL=your_coolify_webhook_url

# PDF Storage
PDF_STORAGE_PATH=./storage/pdfs

# Server Configuration
PORT=5000
FLASK_ENV=development
FRONTEND_URL=http://localhost:5173

# Google Identity Services
GOOGLE_CLIENT_ID=525916855163-4qt3urorpvh8lrs6rqidcscngcmn999d.apps.googleusercontent.com

# Transactional Email (Resend preferred, Plunk still supported)
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key
RESEND_API_URL=https://api.resend.com/emails
RESEND_FROM_EMAIL=Spouse Interview <noreply@spouseinterview.com>
RESEND_REPLY_TO=support@spouseinterview.com
RESEND_TIMEOUT_SECONDS=5
# Plunk secret key must start with sk_*; public pk_* keys are only for tracking events.
PLUNK_SECRET_KEY=sk_your_plunk_secret_key
