# PostgreSQL Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/greencardprep

# JWT Configuration
JWT_SECRET=your-jwt-secret-change-this-to-a-random-string
JWT_EXPIRY_HOURS=168

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID_MONTHLY=price_your_monthly_price_id
STRIPE_PRICE_ID_LIFETIME=price_your_lifetime_price_id
STRIPE_PRICE_ID_INTERVIEW_PASS=price_your_interview_pass_price_id

# AI Provider API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here

# Coolify Deployment
COOLIFY_WEBHOOK_URL=your_coolify_webhook_url

# PDF Storage
PDF_STORAGE_PATH=./storage/pdfs

# Server Configuration
PORT=5000
FLASK_ENV=development
FRONTEND_URL=http://localhost:5173

# Google Identity Services
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Transactional Email (Plunk)
# Secret key must start with sk_*; public pk_* keys are only for tracking events.
PLUNK_SECRET_KEY=sk_your_plunk_secret_key
PLUNK_API_URL=https://next-api.useplunk.com/v1/send
PLUNK_FROM_EMAIL=Spouse Interview <noreply@spouseinterview.com>
PLUNK_REPLY_TO=support@spouseinterview.com
PLUNK_TIMEOUT_SECONDS=5
EMAIL_FROM=Spouse Interview <noreply@spouseinterview.com>
