# API Backend URL
# Copy this file to .env and fill in your API backend URL
VITE_API_URL=http://localhost:5000

# =============================================================================
# AI Provider API Keys (SERVER-SIDE ONLY - set in server/.env)
# =============================================================================
#
# These keys are used ONLY in the Python/Flask backend (server-side).
# They are NOT exposed to the browser or client-side code.
#
# Configure these in server/.env, NOT here.
# =============================================================================

# =============================================================================
# Stripe Configuration (SERVER-SIDE ONLY - set in server/.env)
# =============================================================================
#
# These keys are used ONLY in the Python/Flask backend (server-side).
# They are NOT exposed to the browser or client-side code.
#
# Configure these in server/.env, NOT here.
# =============================================================================

# Stripe Publishable Key (client-safe, used for Stripe.js)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Google Identity Services client ID (client-safe, created in Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
